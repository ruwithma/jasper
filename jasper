WEB_PORTS=""; SMB_DONE=0; VHOST_FQDNS=()
if [[ $DO_SVC -eq 1 || $DO_WEB -eq 1 ]]; then
  phase "SERVICE ENUMERATION"
  # AD boxes: harvest a real userlist FIRST (synchronous) so the Kerberos module can
  # AS-REP/kerberoast it. Triggered by any AD-ish port (SMB/LDAP/Kerberos/RPC).
  if [[ $DO_SVC -eq 1 ]] && { port_open 445 || port_open 139 || port_open 389 || port_open 88 || port_open 135; }; then
    log "AD user discovery -> loot/users.txt"
    nusers=$(discover_ad_users)
    if [[ "${nusers:-0}" -gt 0 ]]; then ok "harvested ${C_BOLD}$nusers${C_RESET} domain users -> loot/users.txt"
    else log "no users harvested unauthenticated (locked-down or non-AD)"; fi
  fi
  for port in $(echo "$OPEN_PORTS" | tr ',' ' '); do
    svc="${SVC[$port]:-}"
    # decide handler from service name first, port number as fallback.
    # web: http/https in the service name, or a known web port (single list)
    if [[ $DO_WEB -eq 1 ]] && { [[ "$svc" == *http* ]] || [[ " $COMMON_WEB_PORTS " == *" $port "* ]]; }; then
      WEB_PORTS="$WEB_PORTS $port"; log "web    :$port"; run_bg enum_web "$port"
    fi
    [[ $DO_SVC -eq 0 ]] && continue
    case "$svc,$port" in
      ftp*|*,21)                 log "ftp    :$port"; run_bg enum_ftp "$port" ;;
      ssh*|*,22)                 log "ssh    :$port"; run_bg enum_ssh "$port" ;;
      telnet*|*,23)              log "telnet :$port"; run_bg enum_telnet "$port" ;;
      vnc*|*,5900|*,5901)        log "vnc    :$port"; run_bg enum_vnc "$port" ;;
      smtp*|*,25|*,465|*,587)    log "smtp   :$port"; run_bg enum_smtp "$port" ;;
      domain*|*,53)              log "dns    :$port"; run_bg enum_dns "$port" ;;
      finger*|*,79)              log "finger :$port"; run_bg enum_finger "$port" ;;
      msrpc*|*,135)              log "msrpc  :$port"; run_bg enum_rpc "$port" ;;
      netbios*|microsoft-ds*|*,139|*,445)
                                 if [[ $SMB_DONE -eq 0 ]]; then SMB_DONE=1; log "smb    :$port"; run_bg enum_smb "$port"; fi ;;
      ldap*|*,389|*,636|*,3268|*,3269)  log "ldap   :$port"; run_bg enum_ldap "$port" ;;
      kerberos*|*,88)            log "krb5   :$port"; run_bg enum_kerberos "$port" ;;
      *,111|*,2049)              log "nfs    :$port"; run_bg enum_nfs "$port" ;;
      ms-sql*|*,1433)            log "mssql  :$port"; run_bg enum_mssql "$port" ;;
      mysql*|*,3306)             log "mysql  :$port"; run_bg enum_mysql "$port" ;;
      postgres*|*,5432)          log "pgsql  :$port"; run_bg enum_pgsql "$port" ;;
      ms-wbt*|*,3389)            log "rdp    :$port"; run_bg enum_rdp "$port" ;;
      *,5985|*,5986)             log "winrm  :$port"; run_bg enum_winrm "$port" ;;
      redis*|*,6379)             log "redis  :$port"; run_bg enum_redis "$port" ;;
      mongod*|*,27017)           log "mongo  :$port"; run_bg enum_mongo "$port" ;;
    esac
  done
  # --- vhost discovery FIRST, then dir-brute the subdomains IN PARALLEL with the
  #     still-running main-host dir-brute (previously a serial second pass = 2x wait) ---
  WEB_PORTS=$(echo $WEB_PORTS | tr ' ' '\n' | grep -E '^[0-9]+$' | sort -un | paste -sd' ' -)
  if [[ $DO_VHOST -eq 1 && -n "$DOMAIN" && "$DOMAIN" == *.* && -n "$WEB_PORTS" ]]; then
    vport=$(echo $WEB_PORTS | tr ' ' '\n' | head -1); vscheme=$(scheme_for "$vport")
    vbase="$vscheme://$TARGET:$vport"; vwl=$(pick_wl "$WL_VHOST" "$WL_VHOST_SMALL" /usr/share/amass/wordlists/namelist.txt)
    have amass && run_bg bash -c "timeout 120 amass enum -passive -d '$DOMAIN' -o '$OUTDIR/vhost/amass.txt' >/dev/null 2>&1"
    if [[ -n "$vwl" ]] && have ffuf; then
      log "vhost  : fuzzing Host FUZZ.$DOMAIN on $vbase"
      # -ac auto-calibrates against several junk hosts so a wildcard/catch-all vhost
      # (which answers 200 for everything, with size varying by hostname length) gets
      # filtered dynamically - a single -fs size baseline can't catch that and floods
      # the results with every wordlist entry.
      bash -c "fs=\$(curl -sS -k -m 10 -H 'Host: zzjasper$RANDOM.$DOMAIN' '$vbase/' 2>/dev/null | wc -c); ffuf -u '$vbase/' -H 'Host: FUZZ.$DOMAIN' -w '$vwl' -t $THREADS -ac -fs \$fs -o '$OUTDIR/vhost/vhost.json' -of json -s >/dev/null 2>&1" &
      VFUZZ_PID=$!
      wait "$VFUZZ_PID" 2>/dev/null   # only the fuzz; main-host enum keeps running in background
      # parse discovered vhosts (raw FUZZ word, strip any stray domain suffix)
      if [[ -f "$OUTDIR/vhost/vhost.json" ]]; then
        mapfile -t VH < <(jq -r '.results[]?.input.FUZZ // .results[]?.host' "$OUTDIR/vhost/vhost.json" 2>/dev/null \
                          | sed -E "s/\.?${DOMAIN//./\\.}\$//" | grep -E '^[a-zA-Z0-9][a-zA-Z0-9._-]*$' | sort -u)
        if (( ${#VH[@]} > 25 )); then
          warn "vhost fuzz returned ${#VH[@]} hits - almost certainly a wildcard/catch-all (filter unreliable). NOT auto-adding; review vhost/vhost.json by hand"
          sumh "VHOSTS"; echo "wildcard suspected (${#VH[@]} hits) - not auto-added; see vhost/vhost.json" >> "$SUMMARY"
        elif (( ${#VH[@]} > 0 )); then
          ok "vhosts discovered:"; sumh "VHOSTS"
          for h in "${VH[@]}"; do
            [[ -z "$h" ]] && continue
            fq="$h.$DOMAIN"; VHOST_FQDNS+=("$fq")
            printf '      %s%s%s\n' "${C_BOLD}" "$fq" "${C_RESET}"
            echo "$fq" >> "$SUMMARY"; add_host_entry "$fq"
          done
          # launch each subdomain's dir-brute now - overlaps the main-host feroxbuster
          # still running, so the two web passes finish together instead of back-to-back
          if [[ $DO_WEB -eq 1 ]]; then
            for fq in "${VHOST_FQDNS[@]}"; do
              for wp in $WEB_PORTS; do log "web    :$wp ${G_ARROW} $fq"; run_bg enum_web "$wp" "$fq"; done
            done
          fi
        fi
      fi
    fi
  fi

  # --- join the backgrounded UDP scan + dispatch UDP-service enumeration ---
  if [[ -n "$UDP_PID" ]]; then
    wait "$UDP_PID" 2>/dev/null
    if grep -qE '^[0-9]+/udp +open' "$OUTDIR/scans/udp.txt" 2>/dev/null; then
      ok "open UDP:"; grep -E '^[0-9]+/udp +open ' "$OUTDIR/scans/udp.txt" | sed 's/^/    /'
      sumh "OPEN UDP"; grep -E '^[0-9]+/udp +open ' "$OUTDIR/scans/udp.txt" >> "$SUMMARY"
      while read -r ln; do UDP_SVC[${ln%%/*}]=$(awk '{print $3}' <<<"$ln"); done \
        < <(grep -E '^[0-9]+/udp +open ' "$OUTDIR/scans/udp.txt")
    fi
  fi
  for uport in "${!UDP_SVC[@]}"; do
    case "${UDP_SVC[$uport]},$uport" in
      snmp*|*,161) log "snmp   :$uport/udp"; run_bg enum_snmp "$uport" ;;
      domain*|*,53) run_bg enum_dns "$uport" ;;
    esac
  done

  log "waiting for enumeration jobs..."
  wait
  ok "enumeration done"
fi

# ---------------------------------------------------------------------------
# PHASE 5b - authenticated re-enum + credential spray (only with -u)
# ---------------------------------------------------------------------------
if [[ -n "$CRED_USER" ]]; then
  if [[ -z "$CRED_PASS" && -z "$CRED_HASH" ]]; then
    warn "-u given without -p/-H - skipping authenticated pass (need a password or hash)"
  else
    CRED_DOMAIN=""; [[ $LOCAL_AUTH -eq 0 ]] && CRED_DOMAIN="$DOMAIN"
    phase "AUTHENTICATED ENUM (creds: ${CRED_DOMAIN:+$CRED_DOMAIN/}$CRED_USER)"
    log "spraying creds across open protocols + roasting"
    auth_enum
    ok "authenticated pass done -> services/auth_creds.txt"
    grep -iE 'Pwn3d|\[\+\]|\$krb5' "$SVCDIR/auth_creds.txt" 2>/dev/null | grep -viE 'https://' | sed 's/^/      /' | head -20
  fi
fi

# ---------------------------------------------------------------------------
# PHASE 6 - aggregate findings
# ---------------------------------------------------------------------------
phase "KEY FINDINGS"

# discover more hosts from web redirects, add them
if [[ -n "$(ls "$OUTDIR"/web/headers_* 2>/dev/null)" ]]; then
  mapfile -t NEW_HOSTS < <(harvest_hostnames "$OUTDIR"/web/headers_*.txt)
  for h in "${NEW_HOSTS[@]}"; do
    printf '%s\n' "${DISCOVERED_HOSTS[@]}" | grep -qxF "$h" && continue
    DISCOVERED_HOSTS+=("$h"); add_host_entry "$h"
  done
fi

# web dir results (primary host)
sumh "WEB FINDINGS"
report_web_dirs "$WEB_HOST"

# service highlights: pull the high-signal lines out of each services/ file
sumh "SERVICE HIGHLIGHTS"
if compgen -G "$SVCDIR/*.txt" >/dev/null; then
  for f in "$SVCDIR"/*.txt; do
    hits=$(grep -iE 'anonymous|allowed|READ|WRITE|share|namingContext|dnsHostName|\$krb5|does not require|community|export|empty.?password|ms17-010|VULNERABLE|guest|Disk|IPC|bypass|CVE-|publickey|password auth|Pwn3d' "$f" 2>/dev/null \
           | grep -viE 'NT_STATUS_ACCESS_DENIED|failed|no entries|^note:|next steps|^  (AS-REP roast|Kerberoast|user enum) ' \
           | sed -E 's/^[[:space:]]*\|_?[[:space:]]*//; s/[[:space:]]+$//' | grep -vE '^$' | sort -u | head -15)
    if [[ -n "$hits" ]]; then
      base=$(basename "$f" .txt); ok "${C_BOLD}$base${C_RESET}"
      echo "$hits" | sed "s/^/      ${C_DIM}/; s/\$/${C_RESET}/"
      echo "### $base" >> "$SUMMARY"; echo "$hits" | sed 's/^/  /' >> "$SUMMARY"
    fi
  done
else
  log "no service modules produced output"
fi

# vhost web dir results - subdomains were fuzzed + dir-brute'd in parallel during
# service enumeration (PHASE 5), so here we only report what they turned up.
if (( ${#VHOST_FQDNS[@]} > 0 )); then
  sumh "VHOST WEB FINDINGS"
  for fq in "${VHOST_FQDNS[@]}"; do report_web_dirs "$fq"; done
fi

# ranked, do-this-first attack surface (scans everything gathered above)
prioritize

# ---------------------------------------------------------------------------
phase "DONE"
ok "output ${C_BOLD}$OUTDIR/${C_RESET} ${G_ARROW} read ${C_BOLD}$OUTDIR/SUMMARY.txt${C_RESET}"
# output tree, dimmed connectors
tree_line(){ printf '  %s%s%s %s%-10s%s %s\n' "${C_DIM}" "$1" "${C_RESET}" "${C_CYN}" "$2" "${C_RESET}" "${C_DIM}$3${C_RESET}"; }
tree_line "├─" "scans/"    "rustscan + nmap (tcp, udp, services)"
tree_line "├─" "services/" "per-service enum (smb, ldap, ftp, snmp, ...)"
tree_line "├─" "web/"      "fingerprints, dir brute, wpscan, nuclei"
tree_line "├─" "vhost/"    "vhost + passive subdomains"
tree_line "╰─" "loot/"     "/etc/hosts backup + scratch"
if [[ ${#DISCOVERED_HOSTS[@]} -gt 0 ]]; then
  [[ $IS_ROOT -eq 1 ]] && ok "hosts mapped: ${C_BOLD}${DISCOVERED_HOSTS[*]}${C_RESET}" \
                       || warn "run ${C_BOLD}sudo jasper $TARGET${C_RESET} to auto-map: ${DISCOVERED_HOSTS[*]}"
fi
echo
printf '%s %sjasper v%s complete%s %sin %s%s\n' \
  "${C_GRN}${C_BOLD}$G_OK${C_RESET}" "${C_BOLD}" "$VERSION" "${C_RESET}" "${C_DIM}" "$(_el)" "${C_RESET}"
